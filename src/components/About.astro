---
import IconBolt from "./icon/IconBolt.astro";
import IconCode from "./icon/IconCode.astro";
import IconLight from "./icon/IconLight.astro";
import IconUsers from "./icon/IconUsers.astro";
---

<section  id="about" class="py-20 px-4 md:px-0">
  <div class="flex items-center flex-row mb-6 text-blue-300">
    <IconUsers class="w-8 h-8 mr-4" />
    <h2 class="text-4xl font-bold">
      Sobre nosotros 
    </h2>
  </div>
  <span class="text-2xl font-extralight text-blue-300 italic">Somos SOFSA.</span>
  <p class="mt-4 text-lg text-gray-300 md:max-w-2xl">
    Somos un equipo de desarrolladores freelance apasionados por la tecnología y
    la creación de soluciones digitales a medida. Trabajamos de forma
    colaborativa para ofrecer productos de alta calidad, combinando diseño,
    desarrollo y buenas prácticas modernas.
  </p>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8">
    <article class="flex items-center flex-col p-4 py-8 rounded-2xl bg-blue-700/10 border-2 border-blue-700/20">
      <IconLight class="w-14 h-14 text-blue-500 mb-4" />
      <h3 class="text-center text-lg font-bold text-blue-300">Enfoque en Soluciones Reales</h3>
    </article>

    <article class="flex items-center flex-col p-4 py-8 rounded-2xl bg-blue-700/10 border-2 border-blue-700/20">
      <IconBolt class="w-14 h-14 text-blue-500 mb-4" />
      <h3 class="text-center text-lg font-bold text-blue-300">Desarrollo Ágil</h3>
    </article>

    <article class="flex items-center flex-col p-4 py-8 rounded-2xl bg-blue-700/10 border-2 border-blue-700/20">
      <IconUsers class="w-14 h-14 text-blue-500 mb-4" />
      <h3 class="text-center text-lg font-bold text-blue-300">Trabajo en Equipo</h3>
    </article>

    <article class="flex items-center flex-col p-4 py-8 rounded-2xl bg-blue-700/10 border-2 border-blue-700/20">
      <IconCode class="w-14 h-14 text-blue-500 mb-4" />
      <h3 class="text-center text-lg font-bold text-blue-300">Código Limpio y Mantenible</h3>
    </article>

  </div>
</section>
