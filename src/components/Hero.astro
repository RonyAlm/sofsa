---
import IconCode from "./icon/IconCode.astro";
import IconMail from "./icon/IconMail.astro";
---

<section class="flex flex-col md:flex-row items-center justify-center px-4 md:px-0">
    <div class="md:w-1/2 flex flex-col p-4 md:py-10 mb-6 md:mb-0">
        <h2 class="md:max-w-lg py-2 text-4xl font-bold bg-linear-to-r from-blue-500 to-purple-600 bg-clip-text text-transparent">Desarrollamos software a medida para hacer crecer tu negocio</h2>
        <p class="md:max-w-lg text-2xl text-gray-300 mt-4">En SOFSA somos un equipo freelance que transforma ideas en soluciones digitales modernas, escalables y eficientes.</p>
        <div class="flex gap-4 mt-8">
            <a class="bg-blue-700 text-white/80 px-4 py-2 pr-6 rounded-full" href="#contact">
                <IconMail class="w-6 h-6 inline-block mr-2" />
                <span>Contactanos</span>
            </a>
            <!-- <a class="bg-gray/10 border-2 text-blue-700 px-4 py-2 rounded-full" href="/projects">
                <IconCode class="w-6 h-6 inline-block mr-2" />
                <span>Proyectos</span>
            </a> -->
        </div>
    </div>
    <div class="md:w-1/2">
        <img src="/img/hero.jpg" alt="Hero" class="w-lg rounded-3xl">
    </div>
</section>